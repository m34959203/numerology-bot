# --- Telegram ---
# Токен бота от @BotFather
BOT_TOKEN=123456:CHANGE_ME
# ID администраторов через запятую (возвраты, управление услугами)
ADMIN_IDS=123456789
# Чат(ы) мастера для заявок на ручные тарифы (детские/совместимость), через запятую.
# Пусто → заявки уходят в ADMIN_IDS. Мастер должен один раз нажать Start у бота.
MASTER_CHAT_ID=

# --- База данных ---
# PostgreSQL через asyncpg. При docker-compose host = db (имя сервиса).
DATABASE_URL=postgresql+asyncpg://numerology:CHANGE_ME@localhost:5432/numerology

# Для docker-compose (создаёт БД и подставляется в DATABASE_URL контейнера bot):
POSTGRES_USER=numerology
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=numerology

# --- Расчёты ---
# Путь к Excel-источнику истины (используется только скриптом выгрузки текстов)
EXCEL_SOURCE_PATH=./ПРОГРАММА_МАТРИЦА_на_русском.xlsx

# --- Выдача отчёта ---
# text | pdf | both
REPORT_FORMAT=pdf
# Путь к TTF-шрифту с кириллицей для PDF (пусто = поиск по системным путям).
# В Docker: apt-get install -y fonts-dejavu-core
PDF_FONT_PATH=

# --- Режим запуска ---
# polling | webhook
RUN_MODE=polling
# Только для webhook:
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/webhook

# --- Логирование ---
LOG_LEVEL=INFO
